# App
APP_NAME=Crowscap API
APP_ENV=development
API_V1_PREFIX=/api/v1

# Database
# Phase 0 default: local SQLite.
DATABASE_URL=sqlite:///./crowscap_dev.db
# Alibaba RDS PostgreSQL target example:
# DATABASE_URL=postgresql+psycopg://crowscap_app:replace-password@rm-xxxx.pg.rds.aliyuncs.com:5432/crowscap?sslmode=require
# Optional source used only by scripts/migrate_sqlite_to_postgres.py.
SQLITE_DATABASE_URL=sqlite:///./crowscap_dev.db

# Qwen Cloud
# Never commit a real key. Qwen docs use DASHSCOPE_API_KEY.
DASHSCOPE_API_KEY=
# Use the OpenAI Compatible Endpoint shown in your Qwen Cloud workspace.
# The docs default is: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Hackathon workspaces may show a region/workspace-specific endpoint like:
# https://ws-your-workspace.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.7-plus
QWEN_FAST_MODEL=qwen-turbo
QWEN_CHAT_MODEL=qwen-plus
QWEN_EXTRACTION_MODEL=qwen-plus
QWEN_RELATIONSHIP_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank
QWEN_BELIEF_AUDIT_MODEL=qwen-plus

# Optional. Improves YouTube title/description/channel metadata when transcript
# access is blocked. Without it, Crowscap falls back to YouTube oEmbed metadata.
YOUTUBE_DATA_API_KEY=

# Relationship detection
# Minimum cosine score for "worth asking Qwen about this memory pair".
RELATIONSHIP_CANDIDATE_MIN_SCORE=0.50
RELATIONSHIP_CANDIDATE_LIMIT=3
RELATIONSHIP_PAIR_LIMIT=4
# Pairs above this are treated as likely repeats/near-duplicates and skipped for tension checks.
RELATIONSHIP_NEAR_DUPLICATE_MAX_SCORE=0.75
# Relationship checks are non-critical, so fail fast instead of holding capture for minutes.
RELATIONSHIP_TIMEOUT_SECONDS=20
RELATIONSHIP_MAX_RETRIES=0

# Recall
RECALL_DUE_LIMIT=50

# Public evidence search
# "auto" tries Jina first, then falls back to DuckDuckGo HTML source leads.
# Use "disabled" to turn public evidence off.
PUBLIC_SEARCH_PROVIDER=auto
PUBLIC_SEARCH_BASE_URL=https://s.jina.ai/
PUBLIC_SEARCH_DUCKDUCKGO_URL=https://html.duckduckgo.com/html/
PUBLIC_SEARCH_TIMEOUT_SECONDS=10

# MCP server for Qwen Cloud / agent clients.
# Local SSE URL with defaults: http://127.0.0.1:8010/mcp/sse
CROWSCAP_MCP_ENABLED=false
CROWSCAP_MCP_HOST=127.0.0.1
CROWSCAP_MCP_PORT=8010
CROWSCAP_MCP_TRANSPORT=sse
CROWSCAP_MCP_SSE_PATH=/mcp/sse
CROWSCAP_MCP_MESSAGE_PATH=/mcp/messages/
CROWSCAP_MCP_STREAMABLE_HTTP_PATH=/mcp

# Frontend auth proxy
# Must match CROWSCAP_PROXY_SECRET in the Next.js frontend environment.
CROWSCAP_PROXY_SECRET=replace-with-a-long-random-secret
CROWSCAP_AUTH_REQUIRED=true
