# App
APP_NAME=Crowscap API
APP_ENV=development
API_V1_PREFIX=/api/v1

# Database
# Phase 0 default: local SQLite.
DATABASE_URL=sqlite:///./crowscap_dev.db

# Qwen Cloud
# Never commit a real key. Qwen docs use DASHSCOPE_API_KEY.
DASHSCOPE_API_KEY=
# Use the OpenAI Compatible Endpoint shown in your Qwen Cloud workspace.
# The docs default is: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Hackathon workspaces may show a region/workspace-specific endpoint like:
# https://ws-your-workspace.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.7-plus
QWEN_FAST_MODEL=qwen3.6-flash
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank

# Relationship detection
# Minimum cosine score for "worth asking Qwen about this memory pair".
RELATIONSHIP_CANDIDATE_MIN_SCORE=0.30
RELATIONSHIP_CANDIDATE_LIMIT=5
